{
  "hardware": {
    "sensors": [
      {
        "drive_gpio": 16,
        "read_gpio": 20,
        "label": "Top Sensor"
      },
      {
        "drive_gpio": 21,
        "read_gpio": 26,
        "label": "Bottom Sensor"
      }
    ],
    "valves": [
      {
        "gpio": 14,
        "label": "Valve Air",
        "open_ms": 0,
        "close_ms": 0
      },
      {
        "gpio": 15,
        "label": "Valve Vacuum",
        "open_ms": 0,
        "close_ms": 0
      },
      {
        "gpio": 18,
        "label": "Valve Water Pump",
        "open_ms": 0,
        "close_ms": 0
      },
      {
        "gpio": 23,
        "label": "Valve Maple Trees",
        "open_ms": 0,
        "close_ms": 0
      },
      {
        "gpio": 24,
        "label": "Water Pump",
        "open_ms": 0,
        "close_ms": 0
      }
    ],
    "valve_inverted": true
  },
  "settings": {
    "poll_interval_ms": 100,
    "default_valve_states": [
      1,
      0,
      0,
      0,
      0
    ]
  },
  "mode": "sequence",
  "modes": {
    "sequence": {
      "on_sensor_high": {
        "name": "Vidange",
        "steps": [
          {
            "valve_index": 0,
            "state": 1,
            "delay_after_ms": 0
          }
        ],
        "min_run_seconds": 0,
        "min_run_extra": true
      },
      "on_sensor_low": {
        "name": "Remplissage",
        "steps": [
          {
            "valve_index": 0,
            "state": 0,
            "delay_after_ms": 0
          }
        ],
        "min_run_seconds": 0,
        "min_run_extra": true
      }
    },
    "alternance": {
      "sequences": [
        {
          "name": "Phase A",
          "steps": [
            {
              "valve_index": 0,
              "state": 1,
              "delay_after_ms": 0
            },
            {
              "valve_index": 1,
              "state": 0,
              "delay_after_ms": 0
            }
          ],
          "min_run_seconds": 0,
          "min_run_extra": true,
          "delay_after_ms": 3000
        },
        {
          "name": "Phase B",
          "steps": [
            {
              "valve_index": 0,
              "state": 0,
              "delay_after_ms": 0
            },
            {
              "valve_index": 1,
              "state": 1,
              "delay_after_ms": 0
            }
          ],
          "min_run_seconds": 0,
          "min_run_extra": true,
          "delay_after_ms": 3000
        }
      ]
    }
  }
}